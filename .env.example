# RAG backend: "ollama" (default, local/free) or "gemini" (Google free tier)
RAG_BACKEND=ollama

# Ollama settings (only needed if RAG_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma4:e4b

# Gemini settings (only needed if RAG_BACKEND=gemini)
GEMINI_API_KEY=

# Optional overrides
CHROMA_PATH=data/chroma
COLLECTION_NAME=flights
RETRIEVE_N=5

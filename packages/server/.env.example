# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://flightselect:flightselect_password@localhost:5432/flightselect_db"

# Redis
REDIS_URL="redis://localhost:6379"

# AI Service (placeholder — not yet implemented)
AI_SERVICE_API_KEY=your_anthropic_or_openai_api_key_here
AI_SERVICE_MODEL=claude-3-opus-20240229

# Amadeus API (placeholder — see https://developers.amadeus.com/ for real credentials)
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here

# CORS allowed origin (comma-separate multiple or use * for open dev)
CORS_ORIGIN=http://localhost:5173

# RAG internal shared secret (must match RAG_INTERNAL_SECRET in root .env)
RAG_INTERNAL_SECRET=changeme-use-strong-secret-in-prod
